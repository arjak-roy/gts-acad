{
  "name": "gts-academy-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:seed": "node prisma/seed.mjs",
    "db:reshape": "node scripts/prisma-env.mjs DATABASE_URL db execute --file prisma/manual-migrations/20260402_course_hierarchy.sql --schema prisma/schema.prisma",
    "db:test:up": "docker compose -f docker-compose.test.yml up -d postgres_test",
    "db:test:down": "docker compose -f docker-compose.test.yml down",
    "db:test:logs": "docker compose -f docker-compose.test.yml logs -f postgres_test",
    "db:test:reshape": "node scripts/prisma-env.mjs TEST_DATABASE_URL db execute --file prisma/manual-migrations/20260402_course_hierarchy.sql --schema prisma/schema.prisma",
    "db:test:push": "node scripts/prisma-env.mjs TEST_DATABASE_URL db push --skip-generate",
    "db:test:seed": "node scripts/run-seed.mjs TEST_DATABASE_URL",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-table": "^8.21.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^14.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.25",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
