# Primary application database. Required for production and any DB-backed local run.
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/gts_academy?schema=public"

# Test database used by the db:test:* scripts.
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5435/gts_academy_test?schema=public"

# Human-readable application name used across the UI and outbound emails.
APP_NAME="GTS Academy App"

# Public canonical URL. This is also exposed to client-side code via NEXT_PUBLIC_*.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Generic server-side origin fallback used by some email/login link builders.
APP_ORIGIN="http://localhost:3000"

# Internal/admin portal origin for login, account activation, and internal password reset links.
INTERNAL_APP_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_INTERNAL_APP_ORIGIN="http://localhost:3000"

# Candidate-facing app origin. Set these to a separate frontend if candidate flows live elsewhere.
# If you only have one app, keeping them equal to the main app URL is fine.
CANDIDATE_APP_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_CANDIDATE_APP_ORIGIN="http://localhost:3000"

# Session signing and encryption secrets. Keep both stable across deploys.
AUTH_SESSION_SECRET="replace-with-a-long-random-secret"
SETTINGS_ENCRYPTION_SECRET="replace-with-a-second-long-random-secret"

# Session lifetime settings.
AUTH_SESSION_MAX_AGE_SECONDS="28800"
AUTH_REMEMBER_ME_MAX_AGE_SECONDS="2592000"

# Client-visible warning threshold shown before session expiry.
NEXT_PUBLIC_AUTH_SESSION_WARNING_SECONDS="300"

# Password policy and hashing configuration.
AUTH_PASSWORD_MIN_LENGTH="12"
AUTH_BCRYPT_ROUNDS="12"
AUTH_ALLOW_LEGACY_PLAINTEXT_PASSWORDS="false"

# Two-factor authentication behavior.
TWO_FACTOR_CODE_TTL_MINUTES="10"
TWO_FACTOR_RESEND_COOLDOWN_SECONDS="60"

# Candidate login bypass is for controlled non-production testing only.
CANDIDATE_LOGIN_SKIP_2FA="false"

# Account activation and password reset behavior.
AUTH_ACTIVATION_TOKEN_TTL_HOURS="72"
AUTH_ACTIVATION_RESEND_COOLDOWN_SECONDS="60"
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES="30"
AUTH_PASSWORD_RESET_RESEND_COOLDOWN_SECONDS="60"

# Base URL used when composing password reset links.
AUTH_PASSWORD_RESET_URL_BASE="http://localhost:3000"

# Login lockout and brute-force protection.
AUTH_LOGIN_MAX_FAILED_ATTEMPTS="5"
AUTH_LOGIN_LOCKOUT_SECONDS="900"

# SMTP mail transport settings.
# MAIL_MAILER is currently informational only; the runtime transport is selected from the SMTP fields below.
MAIL_MAILER="smtp"
MAIL_HOST="smtp.zeptomail.in"
MAIL_PORT="587"
MAIL_USERNAME="emailapikey"
MAIL_PASSWORD="replace-with-smtp-password"
MAIL_FROM_ADDRESS="no-reply@gts-academy.test"
MAIL_FROM_NAME="${APP_NAME}"

# Parsed as a boolean by the app. Use true/false, yes/no, on/off, or 1/0.
MAIL_ENCRYPTION="true"

# Default admin/support mailbox used by demo and system-generated email flows.
ADMIN_MAIL="resumes@2coms.zohorecruitmail.in"

# Platform-managed fallbacks. Usually leave these commented unless you are mirroring platform behavior locally.
# VERCEL_PROJECT_PRODUCTION_URL="https://your-app.vercel.app"
# VERCEL_URL="https://your-app-git-branch.vercel.app"

# Internal runtime/script variables. Normally do not set these in your .env file manually.
# NODE_ENV="development"
# PRISMA_PRESERVE_ENV_KEYS="DATABASE_URL"