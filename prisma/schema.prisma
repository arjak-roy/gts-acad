  category              LearningResourceCategory?  @relation("LearningResourceCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory           LearningResourceCategory?  @relation("LearningResourceSubcategory", fields: [subcategoryId], references: [id], onDelete: SetNull)
  createdBy             User?                      @relation("LearningResourceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy             User?                      @relation("LearningResourceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
