  scheduleEvents       BatchScheduleEvent[] @relation("ScheduleEventAssessmentPool")
  curriculumStageItems CurriculumStageItem[] @relation("CurriculumAssessmentItems")
  aiJobs               AiAssessmentJob[]

  @@index([questionType], map: "idx_assessment_pool_question_type")
  @@index([difficultyLevel], map: "idx_assessment_pool_difficulty")
  @@map("assessment_pools")
}

