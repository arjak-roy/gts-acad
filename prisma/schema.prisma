  attachments           LearningResourceAttachment[]
  assignments           LearningResourceAssignment[]
  versions              LearningResourceVersion[]
  usages                LearningResourceUsage[]

  @@index([status, visibility, updatedAt], map: "idx_learning_resources_status_visibility_updated")
  @@index([categoryId, subcategoryId], map: "idx_learning_resources_category")
  @@index([contentType, status], map: "idx_learning_resources_type_status")
  @@map("learning_resources")
}

