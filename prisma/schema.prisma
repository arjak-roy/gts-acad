model LearningResource {
  id                    String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("resource_id")
  sourceContentId       String?                    @unique @db.Uuid @map("source_content_id")
  title                 String                     @db.VarChar(255)
  description           String?                    @db.VarChar(2000)
  excerpt               String?                    @db.VarChar(500)
  contentType           ContentType                @map("content_type")
  status                ContentStatus              @default(DRAFT)
  visibility            LearningResourceVisibility @default(PRIVATE)
  categoryId            String?                    @db.Uuid @map("category_id")
  subcategoryId         String?                    @db.Uuid @map("subcategory_id")
  bodyJson              Json?                      @map("body_json")
  renderedHtml          String?                    @map("rendered_html")
  estimatedReadingMinutes Int?                     @map("estimated_reading_minutes")
  fileUrl               String?                    @map("file_url")
  fileName              String?                    @map("file_name") @db.VarChar(255)
  fileSize              Int?                       @map("file_size")
