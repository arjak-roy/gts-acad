model Country {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  isoCode     String    @unique @map("iso_code") @db.VarChar(5)
  states      State[]
  learners    Learner[] @relation("LearnerNationality")

  @@map("countries")
}

model State {
  id        Int      @id @default(autoincrement())
  countryId Int      @map("country_id")
  name      String   @db.VarChar(100)
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  cities    City[]

  @@map("states")
}

model City {
  id              Int              @id @default(autoincrement())
  stateId         Int              @map("state_id")
  name            String           @db.VarChar(100)
  state           State            @relation(fields: [stateId], references: [id], onDelete: Cascade)
  trainingCentres TrainingCentre[]

  @@map("cities")
}

model Currency {
  id     Int     @id @default(autoincrement())
  code   String  @unique @db.VarChar(10)
  symbol String? @db.VarChar(5)

  @@map("currencies")
}

model User {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("user_id")
  email             String             @unique @db.VarChar(255)
  name              String             @map("full_name") @db.VarChar(255)
  phone             String?            @db.VarChar(20)
  password          String             @db.VarChar(255)
  emailVerifiedAt   DateTime?          @map("email_verified_at") @db.Timestamptz(6)
  isActive          Boolean            @default(true) @map("is_active")
  lastLoginAt       DateTime?          @map("last_login_at") @db.Timestamptz(6)
  metadata          Json               @default("{}")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  roleAssignments   UserRoleAssignment[]
  security          UserSecurity?
  twoFactorChallenges TwoFactorChallenge[]
  passwordResetTokens PasswordResetToken[]
  sessions          UserSession[]
  activationTokens  AccountActivationToken[]
  trainerProfile    TrainerProfile?
  learnerAccount    Learner?           @relation("LearnerUser")
  markedAttendance  AttendanceRecord[] @relation("AttendanceMarkedBy")
  recruiterSyncLogs RecruiterSyncLog[] @relation("SyncTriggeredBy")
  interviews        Interview[]        @relation("InterviewedBy")
  createdScheduleEvents BatchScheduleEvent[] @relation("ScheduleEventCreatedBy")
  auditLogs         AuditLog[]         @relation("AuditActor")
  settingsAuditLogs SettingsAuditLog[] @relation("SettingsAuditActor")
  triggeredEmailLogs EmailLog[]        @relation("EmailTriggeredBy")
  createdCourseContents    CourseContent[]          @relation("ContentCreatedBy")
  createdCourseContentFolders CourseContentFolder[] @relation("ContentFolderCreatedBy")
  createdAssessmentPools   AssessmentPool[]         @relation("AssessmentPoolCreatedBy")
  assignedTrainerAssessments TrainerAssessmentAssignment[] @relation("TrainerAssessmentAssignedBy")
  createdQuestionBankQuestions QuestionBankQuestion[] @relation("QuestionBankCreatedBy")
  createdCurricula         Curriculum[]             @relation("CurriculumCreatedBy")
  createdLearningResources LearningResource[]       @relation("LearningResourceCreatedBy")
  updatedLearningResources LearningResource[]       @relation("LearningResourceUpdatedBy")
  assignedLearningResources LearningResourceAssignment[] @relation("LearningResourceAssignedBy")
  learningResourceVersions LearningResourceVersion[] @relation("LearningResourceVersionUpdatedBy")
  learningResourceUsages   LearningResourceUsage[]  @relation("LearningResourceUsageActor")
  assignedBatchContents    BatchContentMapping[]    @relation("BatchContentAssignedBy")
  assignedBatchAssessments BatchAssessmentMapping[] @relation("BatchAssessmentAssignedBy")
  assignedBatchCurricula   BatchCurriculumMapping[] @relation("BatchCurriculumAssignedBy")
  aiAssessmentJobs         AiAssessmentJob[]        @relation("AiJobCreatedBy")
  reviewedAssessmentAttempts AssessmentAttempt[]    @relation("AssessmentAttemptReviewedBy")
  createdEmailTemplates    EmailTemplate[]          @relation("EmailTemplateCreatedBy")
  updatedEmailTemplates    EmailTemplate[]          @relation("EmailTemplateUpdatedBy")
  emailTemplateVersions    EmailTemplateVersion[]   @relation("EmailTemplateVersionUpdatedBy")
  activityLogs             UserActivityLog[]        @relation("UserActivityLogs")

  @@map("users")
}

model UserSecurity {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @unique @db.Uuid @map("user_id")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?   @map("two_factor_secret")
  recoveryCodes     String[]  @map("recovery_codes")
  failedLoginAttempts Int     @default(0) @map("failed_login_attempts")
  loginLockedUntil  DateTime? @map("login_locked_until") @db.Timestamptz(6)
  lastFailedLoginAt DateTime? @map("last_failed_login_at") @db.Timestamptz(6)
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz(6)
  sessionInvalidatedAt DateTime? @map("session_invalidated_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_security")
}

model TwoFactorChallenge {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("challenge_id")
  userId      String    @db.Uuid @map("user_id")
  purpose     String    @db.VarChar(50)
  codeHash    String    @map("code_hash") @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  sentAt      DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt], map: "idx_two_factor_challenges_user_purpose")
  @@index([expiresAt], map: "idx_two_factor_challenges_expires_at")
  @@map("two_factor_challenges")
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("reset_token_id")
  userId     String    @db.Uuid @map("user_id")
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  sentAt     DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  requestIp  String?   @map("request_ip") @db.VarChar(64)
  userAgent  String?   @map("user_agent") @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "idx_password_reset_tokens_user_created")
  @@index([expiresAt], map: "idx_password_reset_tokens_expires_at")
  @@index([tokenHash], map: "idx_password_reset_tokens_token_hash")
  @@map("password_reset_tokens")
}

model UserSession {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("session_id")
  userId         String    @db.Uuid @map("user_id")
  device         String?   @db.VarChar(120)
  browser        String?   @db.VarChar(120)
  ipAddress      String?   @map("ip_address") @db.VarChar(64)
  userAgent      String?   @map("user_agent") @db.VarChar(255)
  rememberMe     Boolean   @default(false) @map("remember_me")
  loginAt        DateTime  @default(now()) @map("login_at") @db.Timestamptz(6)
  lastActivityAt DateTime  @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason  String?   @map("revoked_reason") @db.VarChar(80)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt], map: "idx_user_sessions_user_state")
  @@index([expiresAt], map: "idx_user_sessions_expires_at")
  @@index([lastActivityAt], map: "idx_user_sessions_last_activity")
  @@map("user_sessions")
}

model AccountActivationToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("activation_token_id")
  userId     String    @db.Uuid @map("user_id")
  tokenHash  String    @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  sentAt     DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt], map: "idx_account_activation_tokens_user_created")
  @@index([expiresAt], map: "idx_account_activation_tokens_expires_at")
  @@index([tokenHash], map: "idx_account_activation_tokens_token_hash")
  @@map("account_activation_tokens")
}

model EmailTemplateCategory {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("category_id")
  name        String          @db.VarChar(120)
  code        String          @unique @db.VarChar(80)
  description String?         @db.VarChar(500)
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  templates   EmailTemplate[]

  @@map("email_template_categories")
}

model EmailTemplate {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("template_id")
  key         String                 @unique @map("template_key") @db.VarChar(120)
  name        String                 @db.VarChar(255)
  description String?                @db.VarChar(500)
  subject     String                 @db.VarChar(255)
  htmlContent String                 @map("html_content")
  textContent String?                @map("text_content")
  variables   String[]               @default([])
  isSystem    Boolean                @default(false) @map("is_system")
  isActive    Boolean                @default(true) @map("is_active")
  categoryId  String?                @db.Uuid @map("category_id")
  createdById String?                @db.Uuid @map("created_by_user_id")
  updatedById String?                @db.Uuid @map("updated_by_user_id")
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  category    EmailTemplateCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy   User?                  @relation("EmailTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?                  @relation("EmailTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  versions    EmailTemplateVersion[]

  @@index([isActive, updatedAt], map: "idx_email_templates_active_updated")
  @@index([categoryId], map: "idx_email_templates_category")
  @@map("email_templates")
}

model EmailTemplateVersion {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("version_id")
  templateId    String        @db.Uuid @map("template_id")
  versionNumber Int           @map("version_number")
  subject       String        @db.VarChar(255)
  htmlContent   String        @map("html_content")
  textContent   String?       @map("text_content")
  updatedById   String?       @db.Uuid @map("updated_by_user_id")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  template      EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  updatedBy     User?         @relation("EmailTemplateVersionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([templateId, versionNumber], map: "idx_email_template_versions_template_version")
  @@map("email_template_versions")
}

model EmailTemplateVariable {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("variable_id")
  name        String   @unique @db.VarChar(100)
  label       String   @db.VarChar(255)
  description String?  @db.VarChar(500)
  category    String   @db.VarChar(80)
  sampleValue String?  @map("sample_value") @db.VarChar(500)
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([category], map: "idx_email_template_variables_category")
  @@map("email_template_variables")
}

model EmailLog {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("email_log_id")
  category          EmailLogCategory
  templateKey       String?          @map("template_key") @db.VarChar(120)
  toEmail           String           @map("to_email") @db.VarChar(255)
  subject           String           @db.VarChar(255)
  textBody          String?          @map("text_body")
