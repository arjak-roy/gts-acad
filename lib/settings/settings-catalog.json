        "isRequired": true,
        "isSystem": true,
        "displayOrder": 10,
        "groupName": "Access Protection"
      },
      {
        "key": "auth.password_minimum_length",
        "label": "Password Minimum Length",
        "description": "Minimum required password length.",
        "type": "NUMBER",
        "defaultValue": 12,
        "isRequired": true,
        "isSystem": true,
        "displayOrder": 20,
        "groupName": "Password Policy",
        "validationRules": { "min": 8, "max": 128 }
      },
      {
        "key": "auth.password_complexity_requirement",
        "label": "Password Complexity Requirement",
        "description": "Required password character classes.",
        "type": "MULTI_SELECT",
        "defaultValue": ["UPPERCASE", "LOWERCASE", "NUMBER", "SPECIAL"],
        "isRequired": true,
        "isSystem": true,
        "displayOrder": 30,
        "groupName": "Password Policy",
        "options": [
          { "label": "Uppercase Letter", "value": "UPPERCASE" },
          { "label": "Lowercase Letter", "value": "LOWERCASE" },
          { "label": "Number", "value": "NUMBER" },
          { "label": "Special Character", "value": "SPECIAL" }
        ]
      },
      {
        "key": "auth.session_timeout_duration_minutes",
        "label": "Session Timeout Duration",
        "description": "Default authenticated session lifetime in minutes.",
        "type": "NUMBER",
        "defaultValue": 480,
        "isRequired": true,
        "isSystem": true,
        "displayOrder": 40,
        "groupName": "Sessions",
        "validationRules": { "min": 15, "max": 43200 }
      },
      {
        "key": "auth.maximum_failed_login_attempts",
        "label": "Maximum Failed Login Attempts",
        "description": "Number of failed password attempts before lockout.",
        "type": "NUMBER",
        "defaultValue": 5,
        "isRequired": true,
        "isSystem": true,
        "displayOrder": 50,
        "groupName": "Access Protection",
        "validationRules": { "min": 1, "max": 20 }
      },
      {
        "key": "auth.account_lock_duration_seconds",
        "label": "Account Lock Duration",
        "description": "Account lock duration in seconds after max failed attempts.",
        "type": "NUMBER",
        "defaultValue": 900,
        "isRequired": true,
        "isSystem": true,
        "displayOrder": 60,
        "groupName": "Access Protection",
        "validationRules": { "min": 30, "max": 86400 }
      },
      {
        "key": "auth.allow_multiple_active_sessions",
        "label": "Allow Multiple Active Sessions",
        "description": "Allow users to stay logged in on multiple devices simultaneously.",
        "type": "TOGGLE",
        "defaultValue": true,
        "isRequired": true,
        "isSystem": true,
        "displayOrder": 70,
        "groupName": "Sessions"
      },
      {
        "key": "auth.force_password_change_on_first_login",
        "label": "Force Password Change on First Login",
        "description": "Require first-time users to change their password immediately.",
        "type": "TOGGLE",
        "defaultValue": true,
        "isRequired": true,
        "isSystem": true,
        "displayOrder": 80,
        "groupName": "Password Policy"
      }
