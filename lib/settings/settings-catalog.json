  {
    "name": "Authentication & Security Settings",
    "code": "auth-security",
    "description": "Control password policy, login lockout behavior, sessions, and first-login requirements.",
    "icon": "ShieldCheck",
    "displayOrder": 30,
    "isSystem": true,
    "settings": [
      {
        "key": "auth.enable_two_factor_auth",
        "label": "Enable Two-Factor Authentication",
        "description": "Default two-factor requirement for eligible internal accounts.",
